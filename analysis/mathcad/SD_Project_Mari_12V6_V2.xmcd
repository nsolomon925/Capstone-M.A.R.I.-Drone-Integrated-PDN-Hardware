		<region region-id="1220" left="210" top="279.75" width="463.5" height="72" align-x="227.25" align-y="294" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<text use-page-width="false" push-down="false" lock-width="true">
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">Load Capacitance</p>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit"/>
				<p style="Normal" margin-left="inherit" margin-right="inherit" text-indent="inherit" text-align="inherit" list-style-type="inherit" tabs="inherit">
					<tab/>* The crystal will oscillate at its specified frequency only if the<sp count="5"/>total effective capacitance seen across its terminals is 8 pF</p>
			</text>
		</region>
		<region region-id="1294" left="768" top="286.5" width="123" height="24" align-x="847.5" align-y="300" show-border="false" show-highlight="false" is-protected="true" z-order="0" background-color="inherit" tag="">
			<math optimize="false" disable-calc="false">
				<ml:define xmlns:ml="http://schemas.mathsoft.com/math30">
					<ml:id xml:space="preserve" subscript="OSC">Trace</ml:id>
					<ml:apply>
						<ml:mult style="auto-select"/>
						<ml:real>6</ml:real>
						<ml:id xml:space="preserve">mil</ml:id>
					</ml:apply>
				</ml:define>
